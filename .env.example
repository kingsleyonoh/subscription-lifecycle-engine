# === Application ===
HOST=0.0.0.0
PORT=4000
SECRET_KEY_BASE=xxxxx
PHX_SERVER=true
MIX_ENV=prod

# === Database ===
DATABASE_URL=postgres://sle:xxxxx@localhost:5432/sle_prod
TEST_DATABASE_URL=postgres://sle:sle_password@localhost:5432/sle_test
POOL_SIZE=10

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SOURCE_SLUG=stripe-events

# === Tenant Management ===
SELF_REGISTRATION_ENABLED=true
DEFAULT_TENANT_NAME=Default

# === Dunning Configuration ===
DUNNING_MAX_ATTEMPTS=4
DUNNING_RETRY_INTERVALS=24,72,120,168

# === Ecosystem: Notification Hub ===
NOTIFICATION_HUB_ENABLED=false
NOTIFICATION_HUB_URL=https://notify.kingsleyonoh.com
NOTIFICATION_HUB_API_KEY=xxxxx

# === Ecosystem: Workflow Automation Engine ===
WORKFLOW_ENGINE_ENABLED=false
WORKFLOW_ENGINE_URL=https://workflows.kingsleyonoh.com
WORKFLOW_ENGINE_API_KEY=xxxxx
WORKFLOW_PAYMENT_ROUTING_ID=xxxxx
WORKFLOW_METRICS_REPORT_ID=xxxxx

# === Ecosystem: Transaction Reconciliation Engine ===
RECON_ENGINE_ENABLED=false
RECON_ENGINE_URL=https://recon-engine.kingsleyonoh.com
RECON_ENGINE_API_KEY=xxxxx

# === Ecosystem: Client Management Portal ===
CLIENT_PORTAL_ENABLED=false
CLIENT_PORTAL_URL=https://api.klevar.ai
CLIENT_PORTAL_API_KEY=xxxxx

# === Observability ===
LOG_LEVEL=info
SENTRY_DSN=xxxxx
BETTERSTACK_SOURCE_TOKEN=xxxxx

# === Demo Security ===
# Enable demo security protections (rate limits, usage caps). See CODING_STANDARDS.md § Public Demo Security.
DEMO_MODE=true
